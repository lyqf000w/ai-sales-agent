# Personal Sales Assistant Java backend test environment.
# Copy this file to .env and fill secrets on the server. Do not commit real keys.

SERVER_HOST_PORT=48080
POSTGRES_HOST_PORT=15432
REDIS_HOST_PORT=16379

SERVER_CONTAINER_NAME=ai-sales-server
POSTGRES_CONTAINER_NAME=ai-sales-postgres
REDIS_CONTAINER_NAME=ai-sales-redis

POSTGRES_DB=ai_sales
POSTGRES_USER=ai_sales
POSTGRES_PASSWORD=change-me

MASTER_DATASOURCE_URL=jdbc:postgresql://postgres:5432/ai_sales
MASTER_DATASOURCE_USERNAME=ai_sales
MASTER_DATASOURCE_PASSWORD=change-me
SLAVE_DATASOURCE_URL=jdbc:postgresql://postgres:5432/ai_sales
SLAVE_DATASOURCE_USERNAME=ai_sales
SLAVE_DATASOURCE_PASSWORD=change-me

SPRING_PROFILES_ACTIVE=local
PERSONAL_SALES_BACKEND_ENABLED=false
PERSONAL_SALES_ASSISTANT_SKILL_KEY=
PERSONAL_SALES_ASSISTANT_SKILL_DEFAULT_TENANT_ID=1

AGENT_LLM_DEEPSEEK_ENABLED=true
AGENT_LLM_DEEPSEEK_URL=https://api.deepseek.com/chat/completions
AGENT_LLM_DEEPSEEK_MODEL=deepseek-chat
AGENT_LLM_DEEPSEEK_API_KEY=
